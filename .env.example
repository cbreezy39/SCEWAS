# SMS provider: africastalking | twilio | textbelt
SMS_PROVIDER=africastalking

# Run without sending real SMS
TEST_MODE=True

# Where test messages go: console | emulator   (see Task B)
TEST_TARGET=emulator

# Emulator delivery options (only used when TEST_TARGET=emulator)
EMULATOR_METHOD=emu
EMULATOR_SENDER_ID=0972000000
# ADB_PATH=C:\Android\platform-tools\adb.exe

# Local DB encryption passphrase (any string; a Fernet key is derived from it)
DB_KEY=change-me-to-any-passphrase

# Africa's Talking
AT_USERNAME=sandbox
AT_API_KEY=your_africas_talking_api_key

# Twilio (optional backup)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
